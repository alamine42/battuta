{
  "name": "@battuta/game",
  "version": "0.0.1",
  "description": "Battuta — web-based Arabic-learning RPG for diaspora kids. Phaser 3 + TypeScript + Vite.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "phaser": "^3.86.0",
    "eventemitter3": "^5.0.1",
    "@battuta/schemas": "workspace:*"
  },
  "devDependencies": {
    "@vitest/ui": "^2.1.0",
    "jsdom": "^25.0.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
